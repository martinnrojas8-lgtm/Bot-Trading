# ============================================================
#  CÁLCULO DE EMA
# ============================================================
def calcular_ema(precios: list, periodo: int) -> list:
    if len(precios) < periodo:
        return []
    k = 2 / (periodo + 1)
    emas = [sum(precios[:periodo]) / periodo]
    for precio in precios[periodo:]:
        emas.append(precio * k + emas[-1] * (1 - k))
    return emas

# ============================================================
#  DETECCIÓN DE SEÑAL
# ============================================================
def detectar_senal(velas: list) -> str | None:
    """
    Lógica:
    1. Tendencia definida: EMA9 > EMA21 (alcista) o EMA9 < EMA21 (bajista)
    2. EMAs bien separadas (no enredadas)
    3. Hubo retroceso hacia las EMAs sin romperlas
    4. Vela de continuación confirma la tendencia
    Retorna: "CALL", "PUT" o None
    """
    if len(velas) < CANDLES_NEEDED:
        return None

    cierres = [v["close"] for v in velas]
    ema9_serie  = calcular_ema(cierres, EMA_SHORT)
    ema21_serie = calcular_ema(cierres, EMA_LONG)

    if len(ema9_serie) < 3 or len(ema21_serie) < 3:
        return None

    ema9  = ema9_serie[-1]
    ema21 = ema21_serie[-1]
    ema9_prev  = ema9_serie[-2]
    ema21_prev = ema21_serie[-2]

    # Separación mínima entre EMAs (filtro de rango lateral)
    separacion = abs(ema9 - ema21)
    precio_actual = cierres[-1]
    separacion_pct = separacion / precio_actual * 100
    if separacion_pct < 0.05:
        log.debug("EMAs muy juntas — mercado en rango, sin entrada")
        return None

    # Ambas EMAs deben apuntar en la misma dirección
    tendencia_alcista = ema9 > ema21 and ema9_prev > ema21_prev
    tendencia_bajista = ema9 < ema21 and ema9_prev < ema21_prev

    if not tendencia_alcista and not tendencia_bajista:
        return None

    # Velas recientes para detectar retroceso + continuación
    v_actual   = velas[-1]   # vela de continuación (señal)
    v_retroceso = velas[-2]  # vela de retroceso

    if tendencia_alcista:
        # Retroceso: vela bajista que toca zona de EMAs sin romperlas
        retroceso = (
            v_retroceso["close"] < v_retroceso["open"]  # vela bajista
            and v_retroceso["low"] >= min(ema9_serie[-2], ema21_serie[-2]) * 0.9995
        )
        # Continuación: vela alcista que cierra por encima del retroceso
        continuacion = (
            v_actual["close"] > v_actual["open"]        # vela alcista
            and v_actual["close"] > v_retroceso["open"] # cierra sobre el retroceso
        )
        if retroceso and continuacion:
            return "CALL"

    if tendencia_bajista:
        # Retroceso: vela alcista que toca zona de EMAs sin romperlas
        retroceso = (
            v_retroceso["close"] > v_retroceso["open"]  # vela alcista
            and v_retroceso["high"] <= max(ema9_serie[-2], ema21_serie[-2]) * 1.0005
        )
        # Continuación: vela bajista que cierra por debajo del retroceso
        continuacion = (
            v_actual["close"] < v_actual["open"]        # vela bajista
            and v_actual["close"] < v_retroceso["open"] # cierra bajo el retroceso
        )
        if retroceso and continuacion:
            return "PUT"

    return None

# ============================================================
#  CLASE PRINCIPAL DEL BOT
# ============================================================
class DerivBot:
    def __init__(self):
        self.ws = None
        self.velas = {sym: deque(maxlen=100) for sym in SYMBOLS}
        self.operaciones_abiertas = set()
        self.stats = {"ganadas": 0, "perdidas": 0, "total": 0}

    async def conectar(self):
        log.info("=" * 55)
        log.info("  BOT INICIADO — V25 y V50 | $100 por operación")
        log.info("=" * 55)
        while True:
            try:
                async with websockets.connect(DERIV_WS) as ws:
                    self.ws = ws
                    await self.autenticar()
                    await self.suscribir_velas()
                    await self.escuchar()
            except Exception as e:
                log.error(f"Conexión perdida: {e} — reconectando en 5s...")
                await asyncio.sleep(5)

    async def enviar(self, datos: dict):
        await self.ws.send(json.dumps(datos))

    async def autenticar(self):
        await self.enviar({"authorize": API_TOKEN})
        resp = json.loads(await self.ws.recv())
        if "error" in resp:
            log.error(f"Error de autenticación: {resp['error']['message']}")
            raise Exception("Token inválido")
        balance = resp["authorize"]["balance"]
        currency = resp["authorize"]["currency"]
        log.info(f"✅ Autenticado | Balance: {balance} {currency}")

    async def suscribir_velas(self):
        for symbol in SYMBOLS:
            # Pedir historial de velas primero
            await self.enviar({
                "ticks_history": symbol,
                "granularity": 900,  # 15 minutos en segundos
                "count": CANDLES_NEEDED,
                "end": "latest",
                "style": "candles",
                "subscribe": 1
            })
            log.info(f"📊 Suscripto a velas de {symbol}")

    async def escuchar(self):
        async for mensaje in self.ws:
            datos = json.loads(mensaje)
            msg_type = datos.get("msg_type")

            if msg_type == "candles":
                await self.procesar_historial(datos)
            elif msg_type == "ohlc":
                await self.procesar_vela_nueva(datos)
            elif msg_type == "buy":
                self.procesar_compra(datos)
            elif msg_type == "proposal_open_contract":
                await self.procesar_resultado(datos)
            elif "error" in datos:
                log.warning(f"Error API: {datos['error']['message']}")

    async def procesar_historial(self, datos: dict):
        symbol = datos["echo_req"]["ticks_history"]
        velas_raw = datos.get("candles", [])
        for v in velas_raw:
            self.velas[symbol].append({
                "open":  float(v["open"]),
                "high":  float(v["high"]),
                "low":   float(v["low"]),
                "close": float(v["close"]),
                "epoch": v["epoch"]
            })
        log.info(f"📥 {symbol}: {len(self.velas[symbol])} velas cargadas")

    async def procesar_vela_nueva(self, datos: dict):
        ohlc = datos.get("ohlc", {})
        symbol = ohlc.get("symbol")
        if not symbol or symbol not in SYMBOLS:
            return

        vela = {
            "open":  float(ohlc["open"]),
            "high":  float(ohlc["high"]),
            "low":   float(ohlc["low"]),
            "close": float(ohlc["close"]),
            "epoch": ohlc["epoch"]
        }

        # Actualizar o agregar vela
        if self.velas[symbol] and self.velas[symbol][-1]["epoch"] == vela["epoch"]:
            self.velas[symbol][-1] = vela  # actualizar vela en curso
        else:
            self.velas[symbol].append(vela)  # nueva vela cerrada
            await self.analizar(symbol)

    async def analizar(self, symbol: str):
        if symbol in self.operaciones_abiertas:
            log.info(f"⏳ {symbol}: ya hay una operación abierta, esperando...")
            return

        velas = list(self.velas[symbol])
        senal = detectar_senal(velas)

        cierres = [v["close"] for v in velas]
        ema9  = calcular_ema(cierres, EMA_SHORT)
        ema21 = calcular_ema(cierres, EMA_LONG)

        if senal:
            tendencia = "ALCISTA" if senal == "CALL" else "BAJISTA"
            log.info(f"🎯 SEÑAL en {symbol}")
            log.info(f"   Dirección : {senal} ({tendencia})")
            log.info(f"   EMA9      : {ema9[-1]:.5f}")
            log.info(f"   EMA21     : {ema21[-1]:.5f}")
            log.info(f"   Precio    : {velas[-1]['close']:.5f}")
            await self.operar(symbol, senal)
        else:
            log.info(f"🔍 {symbol}: sin señal | EMA9={ema9[-1]:.5f} EMA21={ema21[-1]:.5f}")

    async def operar(self, symbol: str, direccion: str):
        contract_type = "CALL" if direccion == "CALL" else "PUT"
        self.operaciones_abiertas.add(symbol)

        await self.enviar({
            "buy": 1,
            "price": TRADE_AMOUNT,
            "parameters": {
                "contract_type": contract_type,
                "symbol": symbol,
                "duration": CONTRACT_DURATION,
                "duration_unit": "m",
                "basis": "stake",
                "currency": "USD",
            },
            "subscribe": 1
        })
        log.info(f"📤 Orden enviada: {symbol} | {contract_type} | ${TRADE_AMOUNT} | {CONTRACT_DURATION}min")

    def procesar_compra(self, datos: dict):
        if "error" in datos:
            symbol = datos.get("echo_req", {}).get("parameters", {}).get("symbol", "?")
            log.error(f"❌ Error al comprar {symbol}: {datos['error']['message']}")
            self.operaciones_abiertas.discard(symbol)
            return
        compra = datos.get("buy", {})
        log.info(f"✅ Contrato abierto | ID: {compra.get('contract_id')} | Precio entrada: {compra.get('start_spot')}")

    async def procesar_resultado(self, datos: dict):
        contrato = datos.get("proposal_open_contract", {})
        if not contrato.get("is_expired") and not contrato.get("is_sold"):
            return

        symbol = contrato.get("underlying")
        profit = float(contrato.get("profit", 0))
        resultado = "✅ GANADA" if profit > 0 else "❌ PERDIDA"

        self.stats["total"] += 1
        if profit > 0:
            self.stats["ganadas"] += 1
        else:
            self.stats["perdidas"] += 1

        winrate = (self.stats["ganadas"] / self.stats["total"] * 100) if self.stats["total"] > 0 else 0

        log.info(f"{'='*45}")
        log.info(f"  RESULTADO: {resultado}")
        log.info(f"  Activo   : {symbol}")
        log.info(f"  P&L      : {'+'if profit>0 else ''}{profit:.2f} USD")
        log.info(f"  Stats    : {self.stats['ganadas']}W / {self.stats['perdidas']}L | Winrate: {winrate:.1f}%")
        log.info(f"{'='*45}")

        self.operaciones_abiertas.discard(symbol)

# ============================================================
#  ENTRADA
# ============================================================
if __name__ == "__main__":
    bot = DerivBot()
    asyncio.run(bot.conectar())
